APP_NAME="Autonomous Ops Platform"
APP_ENV=local
APP_KEY=base64:SPjqOT1+3YfCYnv+jEaOJlDajl2LBwaXSBGRINVP3AU=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL (update with your local credentials)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=opsplatform
DB_USERNAME=postgres
DB_PASSWORD=admin
DB_SSLMODE=disable

# Redis (required for queues and cache)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

# Laravel Horizon
HORIZON_PREFIX=ops:horizon:

# AI API keys (required for agents to work)
OPENAI_API_KEY=sk-proj-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Telegram Bot (required for bot functionality)
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME
TELEGRAM_ALLOWED_USERS=CHANGE_ME
TELEGRAM_ADMIN_CHAT_ID=CHANGE_ME

# MinIO / S3 Storage
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=

# ClamAV (optional for local dev — disable in AppServiceProvider if not running)
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
