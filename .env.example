##############################################################################
# Autonomous Ops Platform — Environment Configuration
# Copy to .env and fill in all REQUIRED values before starting the stack.
# Keys marked [REQUIRED] will cause a critical log warning if empty/placeholder.
##############################################################################

APP_NAME="Autonomous Ops Platform"
APP_ENV=local                          # production | staging | local
APP_KEY=                               # [REQUIRED] Run: php artisan key:generate
APP_DEBUG=true                         # MUST be false in production
APP_URL=http://localhost:8080

# ── Logging ──────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                        # production: warning

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────
# Docker service name is 'postgres'; use 127.0.0.1 for local (non-Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=marketing_tech
DB_USERNAME=postgres
DB_PASSWORD=admin                      # [REQUIRED] Change in production

# ── Cache / Session / Queue (Redis) ──────────────────────────────────────
# Docker service name is 'redis'; use 127.0.0.1 for local (non-Docker)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Production session security — set these when APP_ENV=production
SESSION_SECURE_COOKIE=false            # true in production (requires HTTPS)
SESSION_SAME_SITE=lax

# ── AI Providers ─────────────────────────────────────────────────────────
OPENAI_API_KEY=                        # [REQUIRED] sk-proj-...
ANTHROPIC_API_KEY=                     # [REQUIRED] sk-ant-...
GEMINI_API_KEY=

# ── Telegram Bot ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                    # [REQUIRED] From @BotFather
TELEGRAM_WEBHOOK_SECRET=               # [REQUIRED] Random 256-bit hex string
TELEGRAM_ALLOWED_USERS=               # [REQUIRED] Comma-separated Telegram user IDs
TELEGRAM_ADMIN_CHAT_ID=               # [REQUIRED] Your Telegram chat/user ID

# ── File Storage (MinIO / S3) ─────────────────────────────────────────────
FILESYSTEM_DISK=local                  # production: s3
AWS_ACCESS_KEY_ID=                     # Use for AWS S3 — leave empty for MinIO
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# MinIO (Docker — used when FILESYSTEM_DISK=s3 but pointing to local MinIO)
MINIO_KEY=minioadmin
MINIO_SECRET=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=ops-storage
MINIO_ENDPOINT=http://minio:9000      # Use http://localhost:9000 outside Docker

# ── ClamAV (malware scanning) ─────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ── Social Media — feature flags ──────────────────────────────────────────
# DANGER: Set auto_post to true only when real social accounts are connected
SOCIAL_AUTO_POST_ENABLED=false
# Set dry_run=true to log publish intent without calling any real social API
SOCIAL_DRY_RUN=false

# ── Instagram Graph API v19.0 ─────────────────────────────────────────────
SOCIAL_INSTAGRAM_CLIENT_ID=
SOCIAL_INSTAGRAM_CLIENT_SECRET=
SOCIAL_INSTAGRAM_REDIRECT_URI=${APP_URL}/dashboard/social/auth/instagram/callback

# ── Twitter / X API v2 (OAuth 2.0 PKCE) ──────────────────────────────────
SOCIAL_TWITTER_CLIENT_ID=
SOCIAL_TWITTER_CLIENT_SECRET=
SOCIAL_TWITTER_REDIRECT_URI=${APP_URL}/dashboard/social/auth/twitter/callback

# ── LinkedIn API v2 ───────────────────────────────────────────────────────
SOCIAL_LINKEDIN_CLIENT_ID=
SOCIAL_LINKEDIN_CLIENT_SECRET=
SOCIAL_LINKEDIN_REDIRECT_URI=${APP_URL}/dashboard/social/auth/linkedin/callback

# ── Facebook Graph API v19 ────────────────────────────────────────────────
SOCIAL_FACEBOOK_CLIENT_ID=
SOCIAL_FACEBOOK_CLIENT_SECRET=
SOCIAL_FACEBOOK_REDIRECT_URI=${APP_URL}/dashboard/social/auth/facebook/callback

# ── TikTok Content Posting API v2 ────────────────────────────────────────
SOCIAL_TIKTOK_CLIENT_KEY=
SOCIAL_TIKTOK_CLIENT_SECRET=
SOCIAL_TIKTOK_REDIRECT_URI=${APP_URL}/dashboard/social/auth/tiktok/callback

# ── YouTube Data API v3 (Google OAuth2) ──────────────────────────────────
SOCIAL_YOUTUBE_CLIENT_ID=
SOCIAL_YOUTUBE_CLIENT_SECRET=
SOCIAL_YOUTUBE_REDIRECT_URI=${APP_URL}/dashboard/social/auth/youtube/callback

# ── Dashboard Basic Auth ──────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=                    # [REQUIRED] Set a strong password

# ── Dashboard Auth Throttle (requests per minute) ────────────────────────
DASHBOARD_THROTTLE_READ=120
DASHBOARD_THROTTLE_WRITE=60
DASHBOARD_THROTTLE_HEAVY=30

# ── Default Business / Admin Account (used by DefaultBusinessSeeder) ──────
ADMIN_BUSINESS_NAME="My Business"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                        # [REQUIRED] Set a strong password before seeding

# ── Swarm Mode (multi-provider consensus) ─────────────────────────────────
AGENT_SWARM_ENABLED=false              # Set true to fan-out to all configured providers
AGENT_SWARM_MAX_ROUNDS=3
AGENT_SWARM_JUDGE_MODEL=gpt-4o-mini
AGENT_SWARM_JUDGE_PROVIDER=openai
