APP_NAME="Autonomous Ops Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_FALLBACK_CONNECTION=sqlite
DB_SQLITE_DATABASE=/var/www/html/database/database.sqlite
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=opsplatform
DB_USERNAME=postgres
DB_PASSWORD=admin
DB_SSLMODE=disable

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=file
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=redis

HORIZON_PREFIX=ops:horizon:

OPENAI_API_KEY=sk-proj-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME
TELEGRAM_ALLOWED_USERS=CHANGE_ME
TELEGRAM_ADMIN_CHAT_ID=CHANGE_ME

FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=

MINIO_KEY=minioadmin
MINIO_SECRET=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=ops-storage
MINIO_ENDPOINT=http://minio:9000

CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Social Media — feature flags
SOCIAL_AUTO_POST_ENABLED=false
# Set SOCIAL_DRY_RUN=true to log publish intent without calling any real API
SOCIAL_DRY_RUN=false

# Instagram Graph API credentials
SOCIAL_INSTAGRAM_CLIENT_ID=
SOCIAL_INSTAGRAM_CLIENT_SECRET=
SOCIAL_INSTAGRAM_REDIRECT_URI=${APP_URL}/dashboard/social/auth/instagram/callback

# Twitter / X API v2 (OAuth 2.0 PKCE) — developer.twitter.com
SOCIAL_TWITTER_CLIENT_ID=
SOCIAL_TWITTER_CLIENT_SECRET=
SOCIAL_TWITTER_REDIRECT_URI=${APP_URL}/dashboard/social/auth/twitter/callback

# LinkedIn API v2 — developer.linkedin.com
SOCIAL_LINKEDIN_CLIENT_ID=
SOCIAL_LINKEDIN_CLIENT_SECRET=
SOCIAL_LINKEDIN_REDIRECT_URI=${APP_URL}/dashboard/social/auth/linkedin/callback

# Facebook Graph API v19 — developers.facebook.com
SOCIAL_FACEBOOK_CLIENT_ID=
SOCIAL_FACEBOOK_CLIENT_SECRET=
SOCIAL_FACEBOOK_REDIRECT_URI=${APP_URL}/dashboard/social/auth/facebook/callback

# TikTok for Developers Content Posting API v2 — developers.tiktok.com
SOCIAL_TIKTOK_CLIENT_KEY=
SOCIAL_TIKTOK_CLIENT_SECRET=
SOCIAL_TIKTOK_REDIRECT_URI=${APP_URL}/dashboard/social/auth/tiktok/callback

# YouTube Data API v3 (Google OAuth2) — console.cloud.google.com
SOCIAL_YOUTUBE_CLIENT_ID=
SOCIAL_YOUTUBE_CLIENT_SECRET=
SOCIAL_YOUTUBE_REDIRECT_URI=${APP_URL}/dashboard/social/auth/youtube/callback
